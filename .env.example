# ============================================
# PMCopilot Environment Configuration
# ============================================

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# AI Configuration (Gemini Free-Tier Only)
# ============================================

# Required: Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key

# Optional: pooled keys for round-robin rotation (still Gemini only).
# Supports comma, semicolon, or newline-separated values.
# Example:
# GEMINI_API_KEYS=key_1,key_2,key_3,...,key_20

# Optional: numbered key slots (recommended for readability when using many keys).
# You can define as many as needed; app supports at least 20 slots directly.
# GEMINI_API_KEY_1=your_first_gemini_key
# GEMINI_API_KEY_2=your_second_gemini_key
# GEMINI_API_KEY_3=your_third_gemini_key
# ...
# GEMINI_API_KEY_20=your_twentieth_gemini_key

# Optional model override (must remain free-tier-compatible)
# Allowed: gemini-2.5-flash-lite, gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite

# ============================================
# Optional Configuration
# ============================================

# Node Environment
NODE_ENV=development
