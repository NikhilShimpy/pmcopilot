# ============================================
# PMCopilot Environment Configuration
# ============================================

# --------------------------------------------
# Public client + server variables (required)
# --------------------------------------------
# Base app URL used for metadata/canonical links.
# Local development example:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL and publishable anon key.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional Supabase Storage bucket for imports.
NEXT_PUBLIC_IMPORTS_BUCKET=analysis-imports

# --------------------------------------------
# Server-only variables (required)
# --------------------------------------------
# Provide at least one Gemini key using one of these patterns:
# 1) GEMINI_API_KEY
# 2) GEMINI_API_KEYS (comma/semicolon/newline list)
# 3) GEMINI_API_KEY_1 ... GEMINI_API_KEY_N
GEMINI_API_KEY=your_gemini_api_key

# Optional pooled keys for round-robin rotation.
# GEMINI_API_KEYS=key_1,key_2,key_3
# GEMINI_API_KEY_1=your_first_gemini_key
# GEMINI_API_KEY_2=your_second_gemini_key

# Optional model override (free-tier only)
# Allowed: gemini-2.5-flash-lite, gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional service-role key for setup/admin flows.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_optional

# --------------------------------------------
# Runtime environment
# --------------------------------------------
NODE_ENV=development
