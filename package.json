{
  "name": "pmcopilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "setup": "node scripts/setup.js",
    "setup:wizard": "npm run dev & open http://localhost:3000/setup",
    "verify": "curl http://localhost:3000/api/setup/verify",
    "clean": "rm -rf .next && rm -rf node_modules/.cache && echo 'Cache cleared successfully'",
    "clean:all": "rm -rf .next && rm -rf node_modules && echo 'Full clean complete. Run npm install to reinstall dependencies'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.99.2",
    "axios": "^1.13.6",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^9.1.0",
    "recharts": "^3.8.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
